{
  "name": "agentcis-applyims-etl-phase-2",
  "version": "1.0.0",
  "description": "Agencis to ApplyIMS ETL",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*",
    "prepare": "husky",
    "migration:generate": "npx tsx node_modules/typeorm/cli.js -d src/data-source.ts migration:generate",
    "migration:run": "npx tsx node_modules/typeorm/cli.js -d src/data-source.ts migration:run",
    "migration:revert": "npx tsx node_modules/typeorm/cli.js -d src/data-source.ts migration:revert",
    "migration:show": "npx tsx node_modules/typeorm/cli.js -d src/data-source.ts migration:show"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "axios": "^1.6.0",
    "axios-retry": "^4.0.0",
    "config": "^4.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "libphonenumber-js": "^1.13.6",
    "mysql2": "^3.18.1",
    "p-limit": "^4.0.0",
    "pg": "^8.19.0",
    "pg-query-stream": "^4.13.0",
    "rate-limiter-flexible": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/config": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
